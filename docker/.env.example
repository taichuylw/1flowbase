FLOWBASE_WEB_VERSION=latest
FLOWBASE_API_SERVER_VERSION=latest
FLOWBASE_PLUGIN_RUNNER_VERSION=latest
WEB_PORT=3100

DATABASE_MODE=internal
POSTGRES_DB=1flowbase
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_MAX_CONNECTIONS=300
POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=C

API_DATABASE_URL=
EXTERNAL_POSTGRES_HOST=
EXTERNAL_POSTGRES_PORT=5432
EXTERNAL_POSTGRES_DB=1flowbase
EXTERNAL_POSTGRES_USER=postgres
EXTERNAL_POSTGRES_PASSWORD=
EXTERNAL_POSTGRES_SSLMODE=prefer

API_RUST_LOG=info
API_ENV=production
API_ALLOWED_ORIGINS=http://localhost:3100,http://127.0.0.1:3100
API_COOKIE_NAME=flowbase_console_session
API_SESSION_TTL_DAYS=7
API_DATABASE_POOL_MAX_CONNECTIONS=5
API_PROVIDER_SECRET_MASTER_KEY=change-me-provider-secret-master-key
# Selects the GitHub repository that hosts the official plugin registry and packages.
API_OFFICIAL_PLUGIN_REPOSITORY=taichuy/1flowbase-official-plugins
# Points the API server to the official plugin registry manifest.
API_OFFICIAL_PLUGIN_REGISTRY_URL=https://raw.githubusercontent.com/taichuy/1flowbase-official-plugins/main/official-registry.json
# Routes official plugin package downloads through an optional GitHub raw proxy.
API_OFFICIAL_PLUGIN_GITHUB_PROXY_URL=
# Requires official or mirrored plugin packages to pass trusted signature verification.
API_OFFICIAL_PLUGIN_SIGNATURE_REQUIRED=true
API_PLUGIN_SET=default
API_SECRET_RESOLVER=env
API_PLUGIN_ALLOW_UNVERIFIED_FILESYSTEM_DROPINS=false
API_PLUGIN_ALLOW_UPLOADED_HOST_EXTENSIONS=false
# Provides the trusted public keys used to verify official or delegated plugin package signatures.
API_OFFICIAL_PLUGIN_TRUSTED_PUBLIC_KEYS_JSON=[{"key_id":"official-key-2026-04","algorithm":"ed25519","public_key_pem":"-----BEGIN PUBLIC KEY-----\nMCowBQYDK2VwAyEAuk3oonNd85FNP8CBRKj8RVvpdbhreoJiCguEJXPSgwg=\n-----END PUBLIC KEY-----"}]

BOOTSTRAP_WORKSPACE_NAME=1flowbase
BOOTSTRAP_ROOT_ACCOUNT=root
BOOTSTRAP_ROOT_EMAIL=root@example.com
BOOTSTRAP_ROOT_PASSWORD=change-me-root-password
BOOTSTRAP_ROOT_NAME=Root
BOOTSTRAP_ROOT_NICKNAME=Root

PLUGIN_RUNNER_RUST_LOG=info
