# Local development example.
# Browser requests default to the current frontend origin. In development, Vite
# proxies same-origin /api, /health and /openapi.json requests to this backend.
VITE_API_PROXY_TARGET=http://127.0.0.1:7800
# Optional: override browser-side API base URL for non-proxied deployments.
# VITE_API_BASE_URL=https://api.example.com
# Optional: override the domain shown and used by the embedded Scalar viewer.
# Leave empty to use the current frontend origin plus the Vite dev proxy.
# VITE_SCALAR_API_BASE_URL=http://127.0.0.1:3100
