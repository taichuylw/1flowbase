# Local development example.
# Sets the backend target used by the Vite dev proxy for local API requests.
VITE_API_PROXY_TARGET=http://127.0.0.1:7800
# Browser API calls default to the current frontend origin so local development uses the Vite proxy.
# Overrides the browser-side API base URL for non-proxied deployments.
# VITE_API_BASE_URL=https://api.example.com
# Overrides the API base URL displayed and used by the embedded Scalar viewer.
# VITE_SCALAR_API_BASE_URL=http://127.0.0.1:3100
