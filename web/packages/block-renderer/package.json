{
  "name": "@1flowbase/block-renderer",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "main": "./src/index.tsx",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.tsx"
    },
    "./antd-facade": {
      "types": "./dist/antd-facade.d.ts",
      "default": "./src/antd-facade.ts"
    }
  },
  "dependencies": {
    "@1flowbase/antd-facade": "workspace:*",
    "@1flowbase/page-protocol": "workspace:*",
    "antd": "^5.24.6",
    "echarts": "6.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run --passWithNoTests"
  }
}
